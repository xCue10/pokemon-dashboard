# Server
PORT=3001
NODE_ENV=development

# PostgreSQL - Railway provides this automatically in production
DATABASE_URL=postgresql://user:password@localhost:5432/pokemon_dashboard

# Pokemon TCG API - get a free key at https://pokemontcg.io
POKEMON_TCG_API_KEY=your_api_key_here

# eBay fee defaults (can be overridden per listing)
EBAY_FEE_RATE=0.1325
EBAY_FEE_FIXED=0.30
